[Unit]
Description=Novel Hub FastAPI Service
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/novel-hub
EnvironmentFile=/opt/novel-hub/.env
ExecStart=/opt/novel-hub/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8787
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
