{
  "scripts": {
    "build": "npm run build:css && npm run build:js",
    "build:css": "tailwindcss -c tailwind.config.js -i ./app/static/css/tailwind.input.css -o ./app/static/css/tailwind.css --minify",
    "build:js": "esbuild ./app/static/js/editor.js --bundle --format=iife --target=es2020 --outfile=./app/static/js/editor.bundle.js --minify",
    "watch:css": "tailwindcss -c tailwind.config.js -i ./app/static/css/tailwind.input.css -o ./app/static/css/tailwind.css --watch"
  },
  "devDependencies": {
    "@codemirror/autocomplete": "^6.16.0",
    "@codemirror/commands": "^6.5.0",
    "@codemirror/lang-markdown": "^6.2.5",
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.26.3",
    "codemirror": "^6.0.1",
    "esbuild": "^0.25.12",
    "tailwindcss": "3.4.17"
  }
}
