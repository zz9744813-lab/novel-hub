generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  name        String
  creditScore Float    @default(100)
  creditTier  String   @default("A")
  createdAt   DateTime @default(now())

  skills       Skill[]
  timeLogs     TimeLog[]
  commitments  Commitment[]
  reports      Report[]
  creditEvents CreditEvent[]
}

model TimeLog {
  id                  String    @id @default(cuid())
  userId              String
  date                DateTime
  rawInput            String
  parsedAt            DateTime?
  status              String    @default("pending")
  totalRawHours       Float?
  totalEffectiveHours Float?
  conversionRate      Float?
  untrackedHours      Float?
  aiOverallNote       String?

  user    User       @relation(fields: [userId], references: [id])
  entries LogEntry[]

  @@unique([userId, date])
  @@index([userId, date])
}

model LogEntry {
  id             String   @id @default(cuid())
  timeLogId      String
  activity       String
  category       String
  rawHours       Float
  effectiveHours Float
  qualityScore   Float
  deliberate     Boolean  @default(false)
  outputEvidence String?
  aiReason       String?
  source         String   @default("ai")
  skillId        String?

  timeLog TimeLog @relation(fields: [timeLogId], references: [id], onDelete: Cascade)
  skill   Skill?  @relation(fields: [skillId], references: [id])

  @@index([skillId])
  @@index([timeLogId])
}

model Skill {
  id                   String    @id @default(cuid())
  userId               String
  name                 String
  category             String
  description          String?
  isActive             Boolean   @default(true)
  rawHoursTotal        Float     @default(0)
  effectiveHoursTotal  Float     @default(0)
  deliberateHoursTotal Float     @default(0)
  currentLevel         Int       @default(0)
  targetLevel          Int       @default(5)
  lastAssessedAt       DateTime?
  aiComment            String?
  strengths            String?
  weaknesses           String?

  user       User         @relation(fields: [userId], references: [id])
  levels     SkillLevel[]
  logEntries LogEntry[]

  @@unique([userId, name])
  @@index([userId, isActive])
}

model SkillLevel {
  id                   String  @id @default(cuid())
  skillId              String
  level                Int
  levelName            String
  minEffectiveHours    Float
  maxEffectiveHours    Float
  requiredDeliverables String
  assessmentCriteria   String
  masterReference      String?

  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([skillId, level])
}

model Commitment {
  id                 String    @id @default(cuid())
  userId             String
  title              String
  type               String
  startDate          DateTime
  deadline           DateTime
  targetHours        Float
  actualHours        Float     @default(0)
  completionStandard String
  difficulty         Int
  realityCheckPass   Boolean   @default(true)
  realityCheckNote   String?
  status             String    @default("active")
  completionRate     Float?
  onTime             Boolean?
  retroNote          String?
  aiReview           String?
  creditDelta        Float?
  linkedSkillId      String?

  user User @relation(fields: [userId], references: [id])

  @@index([userId, status])
  @@index([userId, deadline])
}

model CreditEvent {
  id          String   @id @default(cuid())
  userId      String
  occurredAt  DateTime @default(now())
  source      String
  sourceId    String?
  delta       Float
  scoreBefore Float
  scoreAfter  Float
  reason      String

  user User @relation(fields: [userId], references: [id])

  @@index([userId, occurredAt])
}

model Report {
  id             String   @id @default(cuid())
  userId         String
  type           String
  scopeKey       String
  generatedAt    DateTime @default(now())
  inputSummary   String
  content        String
  keyFindings    String
  problems       String
  recommendations String
  riskWarnings   String

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, type, scopeKey])
  @@index([userId, type, generatedAt])
}
